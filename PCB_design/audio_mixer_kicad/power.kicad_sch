	(text_box "12V DC Input Bus\n |\n |-► [Boost Converter] -----------> 48V Bus (Phantom Power)\n |                                   |-► LC Filter\n |\n |-► [Boost/Inverting DC-DC] -----> +/- 17V Intermediate\n |                                   |-► [Positive LDO] --> +15V Analog (THAT1606)\n |                                   |-► [Negative LDO] --> -15V Analog (THAT1606)\n |\n |-► [Buck Converter] ------------> 5V Bus (FPGA, ESP32)\n                                     |\n                                     |-► [Standard LDO] --> 3.3V Digital (ADC/DAC Dig, IO)\n                                     |\n                                     |-► [High-PSRR LDO] -> 3.3V Analog (ADC/DAC Ana)"
		(exclude_from_sim no)
